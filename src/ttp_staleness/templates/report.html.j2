<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>TTP Staleness Report — {{ summary.generated_at.date() }}</title>
<style>
  body { font-family: system-ui, sans-serif; max-width: 1200px; margin: 2rem auto; padding: 0 1rem; background: #0f1117; color: #e2e8f0; }
  h1 { margin-bottom: 1rem; }
  .summary { background: #1e2333; border-radius: 8px; padding: 1.5rem; margin-bottom: 1.5rem; display: flex; gap: 2rem; flex-wrap: wrap; }
  .stat { text-align: center; }
  .stat .value { font-size: 2rem; font-weight: bold; }
  .stat .label { font-size: 0.875rem; color: #a0aec0; }
  .critical { color: #fc8181; }
  .high { color: #f6ad55; }
  .medium { color: #f6e05e; }
  .low { color: #68d391; }
  .info { color: #a0aec0; }
  .meta { color: #a0aec0; font-size: 0.875rem; margin-bottom: 2rem; }
  .meta strong { color: #e2e8f0; }
  table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
  th { background: #1e2333; padding: 0.75rem; text-align: left; cursor: pointer; user-select: none; }
  th:hover { background: #2d3748; }
  td { padding: 0.6rem 0.75rem; border-bottom: 1px solid #2d3748; }
  tr:hover { background: #1a2035; }
  .badge { padding: 2px 8px; border-radius: 4px; font-size: 0.75rem; font-weight: bold; }
  .badge-critical { background: #742a2a; color: #fc8181; }
  .badge-high { background: #7b341e; color: #f6ad55; }
  .badge-medium { background: #744210; color: #f6e05e; }
  .badge-low { background: #1c4532; color: #68d391; }
  .badge-info { background: #2d3748; color: #a0aec0; }
</style>
</head>
<body>
<h1>🕵️ TTP Staleness Report</h1>
<div class="summary">
  <div class="stat"><div class="value">{{ summary.total_rules }}</div><div class="label">Rules Scanned</div></div>
  <div class="stat"><div class="value critical">{{ summary.critical }}</div><div class="label">Critical</div></div>
  <div class="stat"><div class="value high">{{ summary.high }}</div><div class="label">High</div></div>
  <div class="stat"><div class="value medium">{{ summary.medium }}</div><div class="label">Medium</div></div>
  <div class="stat"><div class="value low">{{ summary.low }}</div><div class="label">Low</div></div>
  <div class="stat"><div class="value info">{{ summary.no_attack_tags }}</div><div class="label">No Tags</div></div>
</div>
<p class="meta">ATT&amp;CK domain: <strong>{{ summary.attack_domain }}</strong> &middot; Fetched: {{ summary.attack_fetched_at.strftime('%Y-%m-%d %H:%M UTC') }} &middot; Generated: {{ summary.generated_at.strftime('%Y-%m-%d %H:%M UTC') }}</p>
<table id="results">
<thead><tr>
  <th onclick="sortTable(0)">Severity</th>
  <th onclick="sortTable(1)">Rule Title</th>
  <th onclick="sortTable(2)">Technique</th>
  <th onclick="sortTable(3)">Days Stale</th>
  <th onclick="sortTable(4)">Rule Date</th>
  <th onclick="sortTable(5)">ATT&amp;CK Modified</th>
  <th>File</th>
</tr></thead>
<tbody>
{% for score in scores %}
{% for finding in score.findings %}
<tr>
  <td><span class="badge badge-{{ finding.severity }}">{{ finding.severity.upper() }}</span></td>
  <td title="{{ score.title }}">{{ score.title[:60] }}</td>
  <td>{{ finding.technique_id }}{% if finding.technique_name %} &mdash; {{ finding.technique_name[:30] }}{% endif %}</td>
  <td>{{ finding.days_stale or '&mdash;' }}</td>
  <td>{{ finding.rule_effective_date or '&mdash;' }}</td>
  <td>{{ finding.technique_modified.date() if finding.technique_modified else '&mdash;' }}</td>
  <td title="{{ score.source_file }}">{{ score.source_file.name }}</td>
</tr>
{% endfor %}
{% endfor %}
</tbody>
</table>
<script>
function sortTable(col) {
  const table = document.getElementById("results");
  const rows = Array.from(table.tBodies[0].rows);
  const asc = table.dataset.sortCol == col && table.dataset.sortDir == "asc";
  rows.sort((a, b) => {
    const av = a.cells[col].innerText, bv = b.cells[col].innerText;
    return asc ? bv.localeCompare(av, undefined, {numeric: true})
               : av.localeCompare(bv, undefined, {numeric: true});
  });
  rows.forEach(r => table.tBodies[0].appendChild(r));
  table.dataset.sortCol = col;
  table.dataset.sortDir = asc ? "desc" : "asc";
}
</script>
</body></html>
